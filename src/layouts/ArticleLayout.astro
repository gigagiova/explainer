---
import BaseLayout from './BaseLayout.astro';

interface Props {
  frontmatter: {
    title: string;
    subtitle?: string;
    author: string;
    pubDate: Date;
    updatedDate?: Date;
    summary: string;
  };
  sectionId: string;
  sectionTitle: string;
}
const { frontmatter, sectionId, sectionTitle } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout title={`${frontmatter.title} — Explainer`} description={frontmatter.summary}>
  <article class="article">
    <header class="article-header">
      <p class="eyebrow">
        <a href={`${base}/sections/${sectionId}`}>{sectionTitle}</a>
      </p>
      <h1>{frontmatter.title}</h1>
      {frontmatter.subtitle && <p class="subtitle">{frontmatter.subtitle}</p>}
      <div class="article-meta">
        <span>By {frontmatter.author}</span>
        <span>{fmt(new Date(frontmatter.pubDate))}</span>
        {frontmatter.updatedDate && (
          <span>Updated {fmt(new Date(frontmatter.updatedDate))}</span>
        )}
      </div>
    </header>
    <div class="article-body">
      <slot />
    </div>
  </article>
</BaseLayout>
