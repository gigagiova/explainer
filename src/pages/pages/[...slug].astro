---
import { getCollection, getEntry } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const pages = await getCollection('pages', ({ data }) => !data.draft);
  return pages.map((p) => ({ params: { slug: p.slug }, props: { entry: p } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const sectionRef = entry.data.section;
const sectionEntry = await getEntry(sectionRef);
const sectionId = (sectionEntry as any)?.slug ?? (sectionEntry as any)?.id?.replace(/\.[^/.]+$/, '') ?? '';
const sectionTitle = sectionEntry?.data.title ?? sectionId;
---
<ArticleLayout
  frontmatter={entry.data}
  sectionId={sectionId}
  sectionTitle={sectionTitle}
>
  <Content />
</ArticleLayout>
