---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="About — Explainer">
  <article class="article">
    <header class="article-header">
      <p class="eyebrow">About</p>
      <h1>About this site</h1>
      <p class="subtitle">
        A growing library of interactive, intuition-first derivations.
      </p>
    </header>
    <div class="article-body">
      <p>
        Most mathematical writing presents results. Explainer tries to present
        the <em>arguments</em> — the small intuitions that make a derivation feel
        inevitable rather than clever. Each piece pairs careful prose with
        interactive widgets so you can move the pieces of an argument and see
        what changes.
      </p>
      <p>
        The site is built with Astro, MDX, and React. Its source lives on
        GitHub.
      </p>
    </div>
  </article>
</BaseLayout>
